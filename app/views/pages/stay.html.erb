<div data-controller="appear">
  <h1 class="type-serif-heading text-center animate-fade-in-up" style="font-size: var(--text-3xl); margin-bottom: var(--space-4);">Where to Stay</h1>
  <p class="text-center animate-fade-in-up delay-1" style="color: var(--color-text-secondary); margin-bottom: var(--space-12); max-width: 36rem; margin-left: auto; margin-right: auto;">
    The surrounding region offers a beautiful selection of boutique hotels, luxury estates and charming hideaways.
  </p>

  <!-- Recommended Areas -->
  <section style="margin-bottom: var(--space-12);">
    <h2 class="type-serif-heading appear" style="font-size: var(--text-xl); margin-bottom: var(--space-6);">Recommended Areas</h2>

    <div class="space-y-4">
      <div class="card appear">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">Buttersville</h3>
          <p style="color: var(--color-text-secondary);">The nearest town to the venue with charming shops, cafes and easy access.</p>
        </div>
      </div>

      <div class="card appear appear-delay-1">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">Nearby Town A</h3>
          <p style="color: var(--color-text-secondary);">A charming, walkable town filled with markets, restaurants and cobblestone streets.</p>
        </div>
      </div>

      <div class="card appear appear-delay-2">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">Nearby Town B</h3>
          <p style="color: var(--color-text-secondary);">A picturesque village known for its relaxed, elegant atmosphere.</p>
        </div>
      </div>
    </div>
  </section>

  <% if page_enabled?(:hotel) %>
  <!-- Hotel Block -->
  <section style="margin-bottom: var(--space-12);">
    <h2 class="type-serif-heading appear" style="font-size: var(--text-xl); margin-bottom: var(--space-6);">Our Hotel Block</h2>

    <div class="card appear" style="border: 2px solid var(--color-accent); overflow: hidden;">
      <div class="card-body">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: var(--space-3);">
          <div>
            <h3 class="card-title" style="font-size: var(--text-lg);">The Grandview Hotel &amp; Spa</h3>
            <p style="color: var(--color-text-muted); margin-bottom: var(--space-1);">123 Main Street, Buttersville</p>
            <p style="color: var(--color-text-muted); margin-bottom: var(--space-2);">5-minute drive to the venue</p>
          </div>
          <span style="background: var(--color-accent); color: white; font-size: var(--text-xs); font-weight: 600; padding: 2px 10px; border-radius: 999px; white-space: nowrap;">Special Rate</span>
        </div>
        <div style="display: flex; gap: var(--space-4); flex-wrap: wrap; font-size: var(--text-sm); color: var(--color-text-secondary); margin-bottom: var(--space-3);">
          <span>Pool</span>
          <span>Restaurant</span>
          <span>Free WiFi</span>
          <span>Parking</span>
        </div>
        <p style="font-size: var(--text-sm); color: var(--color-text-primary); margin-bottom: var(--space-3);">
          We've reserved a block of rooms at a discounted rate of <strong>$<%= HotelBooking::NIGHTLY_RATE_CENTS / 100 %>/night</strong> for our guests.
          Rooms are limited, so we encourage you to book early.
        </p>
        <%= link_to "Book Your Room", new_hotel_booking_path, class: "btn btn-highlight", style: "display: inline-block;" %>
      </div>
    </div>
  </section>
  <% end %>

  <!-- Hotels -->
  <section>
    <h2 class="type-serif-heading appear" style="font-size: var(--text-xl); margin-bottom: var(--space-6);">Accommodations</h2>

    <div class="space-y-4">
      <div class="card appear">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">The Grand Hotel</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-2);">10-minute drive to Château de Flapjack</p>
          <span style="color: var(--color-accent);">grandhotel.example.com</span>
        </div>
      </div>

      <div class="card appear appear-delay-1">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">Boutique Inn & Spa</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-2);">10-minute drive to Château de Flapjack</p>
          <span style="color: var(--color-accent);">boutiqueinn.example.com</span>
        </div>
      </div>

      <div class="card appear appear-delay-2">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">The Country Estate</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-2);">25-minute drive to Château de Flapjack</p>
          <span style="color: var(--color-accent);">countryestate.example.com</span>
        </div>
      </div>

      <div class="card appear">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">The Little Hotel</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-2);">5-minute drive to Château de Flapjack</p>
          <span style="color: var(--color-accent);">littlehotel.example.com</span>
        </div>
      </div>

      <div class="card appear appear-delay-1">
        <div class="card-body">
          <h3 class="card-title" style="font-size: var(--text-lg);">Vacation Rentals near Buttersville</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-2);">5-minute drive to Château de Flapjack</p>
          <span style="color: var(--color-accent);">airbnb.com</span>
        </div>
      </div>
    </div>
  </section>
</div>
